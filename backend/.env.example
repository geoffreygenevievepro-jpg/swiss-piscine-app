# API terrain Swiss Piscine — configuration backend.
# Copier en .env (gitignored) et renseigner les valeurs.

# --- Odoo (obligatoire) ---
ODOO_URL=https://heiwa.odoo.com/
ODOO_DATABASE=heiwa
ODOO_USERNAME=
# En prod : utiliser une CLÉ API Odoo dédiée, pas le mot de passe du compte.
ODOO_PASSWORD=

# --- Auth / JWT (optionnel, préfixe APP_) ---
# Secret JWT : si vide, généré et persisté dans .secret_key (dev). À définir en prod.
# APP_JWT_SECRET=
# APP_ACCESS_TOKEN_TTL_MIN=15
# APP_REFRESH_TOKEN_TTL_DAYS=30
# APP_MAX_FAILED_ATTEMPTS=5
# APP_LOCKOUT_MINUTES=15
